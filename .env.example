# ============================================
# PawSphere Backend - Environment Variables
# Copy this file to ".env" and fill in real values.
# Never commit your real .env file.
# ============================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database (MySQL) ---
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Example for local XAMPP/MySQL with root and no password:
#   mysql://root:@localhost:3306/db_pawsphere
DATABASE_URL="mysql://root:@localhost:3306/db_pawsphere"

# --- JWT Authentication ---
# Use a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# --- Google Gemini (AI Chat Diagnosa) ---
# Get an API key from https://aistudio.google.com/app/apikey
# If left empty, the AI service automatically falls back to the
# built-in keyword-based triage engine (no external calls).
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Example: http://localhost:5173,http://localhost:3000
CORS_ORIGIN="http://localhost:5173"
